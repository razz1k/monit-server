# Copy to .env and fill in values: cp .env.example .env

# Grafana (docker-compose substitutes these when starting the stack)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=

# Alertmanager Telegram (injected into alertmanager.yml.template at container start)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
